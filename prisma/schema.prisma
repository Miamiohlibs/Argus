generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  id           String           @id @default(uuid())
  clerkUserId  String           @unique
  email        String           @unique
  name         String
  imageUrl     String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  role         Role             @default(user)
  affiliation  UserAffiliation?
  status       UserStatus?
  printSlips   Boolean          @default(false)
  projects     Project[]        @relation("ProjectOwner")
  transactions Transaction[]
  coEditorOn   Project[]        @relation("ProjectCoEditors")
}

model Project {
  id          Int        @id @default(autoincrement())
  title       String
  userId      String
  notes       String?
  needForDate DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  purpose     String     @default("Other")
  bibEntries  BibEntry[]
  user        User       @relation("ProjectOwner", fields: [userId], references: [clerkUserId], onDelete: Cascade)
  coEditors   User[]     @relation("ProjectCoEditors")
}

model BibEntry {
  id               String      @id @default(uuid())
  itemTitle        String
  almaId           String?
  almaIdType       String?
  author           String
  callNumber       String?
  notes            String?
  projectId        Int
  totalItems       Int?        @default(1)
  url              String?
  pub_date         String?
  publisher        String?
  location_codes   String?
  location_display String?
  project          Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items            ItemEntry[]
}

model ItemEntry {
  id            String    @id @default(uuid())
  description   String?
  bibEntryId    String?
  call_number   String?
  copy_id       String?
  barcode       String?
  location_code String?
  location_name String?
  box           String?
  folder        String?
  ms            String?
  BibEntry      BibEntry? @relation(fields: [bibEntryId], references: [id], onDelete: Cascade)
}

model Transaction {
  id        String   @id @default(uuid())
  text      String
  amount    Float
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [clerkUserId], onDelete: Cascade)

  @@index([userId])
}

enum Role {
  user
  editor
  admin
  superadmin
}

enum UserAffiliation {
  Miami
  Other
}

enum UserStatus {
  Undergrad
  Graduate
  Faculty
  Staff
  Alumni
  Other
}
