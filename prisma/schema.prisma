// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// after updating, run 
// `npx prisma generate` to regenerate the Prisma Client
// and `npx prisma migrate dev` to apply the changes to the database
// or `npx prisma db push` to push the changes without migrations
generator client {
  provider = "prisma-client-js"
  // output   = "../app/generated/prisma"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  id           String           @id @default(uuid())
  clerkUserId  String           @unique
  email        String           @unique
  name         String
  role         Role             @default(user)
  affiliation  UserAffiliation?
  status       UserStatus?
  printSlips   Boolean          @default(false)
  imageUrl     String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  transactions Transaction[]
  projects     Project[]        @relation("ProjectOwner")
  coEditorOn   Project[]        @relation("ProjectCoEditors")
}

model Project {
  id          Int        @id @default(autoincrement())
  title       String
  user        User       @relation("ProjectOwner", fields: [userId], references: [clerkUserId], onDelete: Cascade)
  userId      String
  notes       String?
  needForDate DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  bibEntries  BibEntry[]
  coEditors   User[]     @relation("ProjectCoEditors")
}

model BibEntry {
  id               String      @id @default(uuid())
  itemTitle        String
  almaId           String?
  almaIdType       String?
  author           String
  pub_date         String?
  publisher        String?
  callNumber       String?
  // location         String
  location_codes   String?
  location_display String?
  notes            String?
  totalItems       Int?        @default(1)
  url              String?
  items            ItemEntry[]
  projectId        Int
  project          Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ItemEntry {
  id            String    @id @default(uuid())
  description   String?
  // location      String?
  location_code String?
  location_name String?
  call_number   String?
  copy_id       String?
  barcode       String?
  box           String?
  folder        String?
  ms            String?
  BibEntry      BibEntry? @relation(fields: [bibEntryId], references: [id], onDelete: Cascade)
  bibEntryId    String?
}

enum Role {
  user
  editor
  admin
  superadmin
}

enum UserAffiliation {
  Miami
  Other
}

enum UserStatus {
  Undergrad
  Graduate
  Faculty
  Staff
  Alumni
  Other
}

// This was from the original tutorial, not used in Watson
model Transaction {
  id        String   @id @default(uuid())
  text      String
  amount    Float
  //relation to user
  userId    String
  user      User     @relation(fields: [userId], references: [clerkUserId], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}
